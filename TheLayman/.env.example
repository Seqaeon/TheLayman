# Copy to .env for local overrides (never commit .env)

# Path to SQLite database
# Local default: leave unset (uses cache/the_layman.db)
# Render: set to /var/data/the_layman.db via render.yaml
# DB_PATH=/var/data/the_layman.db

# Admin account auto-seeding (used on first boot if no users exist)
# ADMIN_USERNAME=yourname
# ADMIN_PASSWORD=a_strong_password

# LLM model configuration (alternative to saving via the UI)
# LAYMAN_MODEL_BACKEND=openai_compat
# LAYMAN_MODEL_NAME=gemini-2.0-flash
# LAYMAN_OLLAMA_URL=http://127.0.0.1:11434
# LAYMAN_MODEL_TIMEOUT_S=600
# LAYMAN_MODEL_TEMPERATURE=0

# Daily feed generation time (24h UTC, default: 6)
# FEED_SCHEDULE_HOUR=6
